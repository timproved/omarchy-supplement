[Desktop Entry]
Name=Sioyek
Comment=PDF and EPUB viewer for reading technical books and papers
Keywords=pdf;epub;viewer;reader;research;
TryExec=sioyek
Exec=env DESKTOPINTEGRATION=0 APPIMAGELAUNCHER_DISABLE=1 sioyek %f
StartupNotify=true
Terminal=false
Type=Application
Icon=sioyek-icon-linux
Categories=Office;Viewer;
MimeType=application/pdf;application/epub+zip;
